// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS ───────────────────────────────────

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  password    String      // bcrypt, cost factor >= 12. NEVER plaintext.
  name        String
  role        UserRole    @default(ADMIN)
  status      UserStatus  @default(ACTIVE)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lastLoginAt DateTime?

  // Relations
  leads         Lead[]
  activities    ActivityLog[]
  followUps     FollowUp[]
  settings      AdminSettings?

  @@index([role])
  @@index([status])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CLIENT     // Reserved for V2 — do not implement in V1
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// ─── ADMIN SETTINGS (per-admin config) ────────────────────────────
// Each ADMIN has their own WhatsApp Business number and credentials.
// There is NO global WhatsApp config. Each business client = separate Meta setup.
// whatsappToken and smtpPass are AES-256 encrypted before storage.

model AdminSettings {
  id                      String   @id @default(uuid())

  adminId                 String   @unique
  admin                   User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  // WhatsApp (per-admin — each business has their own Meta number)
  whatsappToken           String?  // AES-256 encrypted
  whatsappPhoneNumberId   String?
  whatsappWebhookSecret   String?  // AES-256 encrypted

  // Email (per-admin SMTP)
  smtpHost                String?
  smtpPort                Int?
  smtpUser                String?
  smtpPass                String?  // AES-256 encrypted
  emailFrom               String?

  // Preferences
  timezone                String   @default("Asia/Kolkata")
  reminderLeadTime        Int      @default(30) // minutes before follow-up to fire reminder

  updatedAt               DateTime @updatedAt
}

// ─── SYSTEM SETTINGS (global, SUPER_ADMIN only) ───────────────────
// Platform-level config only. WhatsApp/email config is in AdminSettings.

model SystemSettings {
  id        String   @id @default(cuid())
  settings  Json?
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── LEADS ────────────────────────────────────────────────────────

model Lead {
  id          String      @id @default(uuid())

  // Each lead belongs to one ADMIN (their data space)
  adminId     String
  admin       User        @relation(fields: [adminId], references: [id], onDelete: Cascade)

  name        String
  phone       String
  email       String?
  city        String?
  source      LeadSource  @default(MANUAL)
  status      LeadStatus  @default(NEW)
  remarks     String?
  whatsappOptIn Boolean   @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  activities  ActivityLog[]
  followUps   FollowUp[]

  @@index([adminId])
  @@index([status])
  @@index([phone])
  @@index([createdAt])
  @@unique([adminId, phone]) // Phone unique per admin, not globally
}

enum LeadSource {
  MANUAL
  FACEBOOK
  WHATSAPP
  WEBSITE
  REFERRAL
  OTHER
}

enum LeadStatus {
  NEW
  INTERESTED
  NOT_INTERESTED
  NOT_PICKED
  HOT
  CONVERTED
  FOLLOW_UP
}

// ─── FOLLOW-UPS ───────────────────────────────────────────────────
// Replaces the PHP `follow_up_date + reminder_sent BOOLEAN` pattern.
// A lead can have multiple follow-ups over its lifecycle.
// adminId is intentionally denormalized here for efficient dashboard queries
// ("show today's follow-ups for admin X") without joining through Lead.

model FollowUp {
  id              String          @id @default(uuid())

  leadId          String
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  adminId         String          // Denormalized from lead — kept for query efficiency
  admin           User            @relation(fields: [adminId], references: [id])

  scheduledAt     DateTime        // When the follow-up is due
  status          FollowUpStatus  @default(PENDING)

  reminderSentAt  DateTime?       // Null = reminder not yet fired
  reminderChannel String?         // "whatsapp" | "email" | "both"

  completedAt     DateTime?
  snoozedUntil    DateTime?       // If snoozed, the new target datetime
  notes           String?         // What happened in this follow-up

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([leadId])
  @@index([adminId])
  @@index([scheduledAt])
  @@index([status])
}

enum FollowUpStatus {
  PENDING     // Scheduled, reminder not yet sent
  REMINDED    // Reminder sent, awaiting action
  COMPLETED   // Done
  SNOOZED     // Pushed to snoozedUntil datetime
  CANCELLED
}

// ─── ACTIVITY LOG ─────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(uuid())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])

  // Action strings: "CREATE_LEAD", "UPDATE_STATUS", "SEND_WHATSAPP",
  // "FOLLOW_UP_CREATED", "FOLLOW_UP_COMPLETED", "FOLLOW_UP_SNOOZED", etc.
  action    String
  details   Json?    // { oldValue, newValue, metadata }

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([createdAt])
}
