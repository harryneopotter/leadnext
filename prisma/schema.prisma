// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

// ─── USERS ───────────────────────────────────

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  password    String      // bcrypt, cost factor >= 12. NEVER plaintext.
  name        String
  role        String    @default("ADMIN")
  status      String  @default("ACTIVE")

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lastLoginAt DateTime?

  // Relations
  leads         Lead[]
  activities    ActivityLog[]
  followUps     FollowUp[]
  settings      AdminSettings?

  @@index([role])
  @@index([status])
}

// ─── ADMIN SETTINGS (per-admin config) ────────────────────────────

model AdminSettings {
  id                      String   @id @default(uuid())

  adminId                 String   @unique
  admin                   User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  // WhatsApp (per-admin — each business has their own Meta number)
  whatsappToken           String?  // AES-256 encrypted
  whatsappPhoneNumberId   String?
  whatsappWebhookSecret   String?  // AES-256 encrypted

  // Email (per-admin SMTP)
  smtpHost                String?
  smtpPort                Int?
  smtpUser                String?
  smtpPass                String?  // AES-256 encrypted
  emailFrom               String?

  // Preferences
  timezone                String   @default("Asia/Kolkata")
  reminderLeadTime        Int      @default(30) // minutes before follow-up to fire reminder
  initialLeadQuestions    String?    // Per-admin list of 5-6 initial lead intake questions. Stringified JSON since sqlite doesnt have Json

  updatedAt               DateTime @updatedAt
}

// ─── SYSTEM SETTINGS (global, SUPER_ADMIN only) ───────────────────

model SystemSettings {
  id        String   @id @default(cuid())
  settings  String?  // Stringified json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── LEADS ────────────────────────────────────────────────────────

model Lead {
  id          String      @id @default(uuid())

  // Each lead belongs to one ADMIN (their data space)
  adminId     String
  admin       User        @relation(fields: [adminId], references: [id], onDelete: Cascade)

  name        String
  phone       String
  email       String?
  city        String?
  source      String  @default("MANUAL")
  status      String  @default("NEW")
  remarks     String?
  whatsappOptIn Boolean   @default(false)
  initialQuestionResponses String?   // Captured answers for admin-configured initial questions

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  activities  ActivityLog[]
  followUps   FollowUp[]

  @@index([adminId])
  @@index([status])
  @@index([phone])
  @@index([createdAt])
  @@unique([adminId, phone]) // Phone unique per admin, not globally
}

// ─── FOLLOW-UPS ───────────────────────────────────────────────────

model FollowUp {
  id              String          @id @default(uuid())

  leadId          String
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  adminId         String          // Denormalized from lead — kept for query efficiency
  admin           User            @relation(fields: [adminId], references: [id])

  scheduledAt     DateTime        // When the follow-up is due
  status          String  @default("PENDING")

  reminderSentAt  DateTime?       // Null = reminder not yet fired
  reminderChannel String?         // "whatsapp" | "email" | "both"

  completedAt     DateTime?
  snoozedUntil    DateTime?       // If snoozed, the new target datetime
  notes           String?         // What happened in this follow-up

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([leadId])
  @@index([adminId])
  @@index([scheduledAt])
  @@index([status])
}

// ─── ACTIVITY LOG ─────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(uuid())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])

  // Action strings: "CREATE_LEAD", "UPDATE_STATUS", "SEND_WHATSAPP",
  // "FOLLOW_UP_CREATED", "FOLLOW_UP_COMPLETED", "FOLLOW_UP_SNOOZED", etc.
  action    String
  details   String?    // { oldValue, newValue, metadata }

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([createdAt])
}
